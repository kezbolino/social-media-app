{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-repo-fresh.sh\"",
            "timeout": 20,
            "statusMessage": "Checking repo is fresh (fetching origin)…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/warn-unpushed.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
